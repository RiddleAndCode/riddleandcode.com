{
  "extends": ["html-validate:recommended"],
  "rules": {
    "attr-quotes": "error",
    "no-dup-attr": "error",
    "no-dup-id": "error",

    "no-inline-style": "off",
    "require-sri": "off",
    "void-style": "off",
    "no-trailing-whitespace": "off",
    "long-title": "off",
    "tel-non-breaking": "off",
    "script-type": "off",
    "no-unknown-elements": "off"
  },
  "elements": ["html5"],
  "transform": {}
}
